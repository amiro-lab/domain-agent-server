# ─── LLM 프로바이더 (관리자 페이지에서도 변경 가능) ───────────
LLM_PROVIDER=openai              # openai | anthropic

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini         # gpt-4o-mini | gpt-4o | gpt-4.1-mini | gpt-4.1

# Anthropic (위 대신 사용 시)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── 보안 ───────────────────────────────────────────────────
# 비워두면 시작 시 자동 생성 (재시작마다 로그인 토큰 무효화됨)
# 프로덕션에서는 반드시 고정값으로 설정:  openssl rand -hex 32
JWT_SECRET=

# ─── DB ─────────────────────────────────────────────────────
# 기본: SQLite (Docker 볼륨에 저장)
DATABASE_URL=sqlite:////data/domain_agent.db

# PostgreSQL 사용 시
# DATABASE_URL=postgresql://user:password@localhost:5432/domain_agent

# ─── 타임존 ─────────────────────────────────────────────────
TZ=Asia/Seoul
